# Copy to .env and edit. The compose file reads from .env automatically.

# --------------------------------------------------------------------------
# Hostname / TLS
# --------------------------------------------------------------------------
# SITE_ADDRESS is Caddy's site label AND the cookie domain for oauth2-proxy.
# In production it MUST be a real FQDN with a DNS A record pointing at this
# VM — oauth2-proxy + OIDC + auto-HTTPS all assume this.
#
#   claudelab.ntiva.com          Production (current). Caddy auto-fetches
#                                a real Let's Encrypt cert; oauth2-proxy
#                                sets a Secure cookie scoped to this
#                                domain. Ports 80+443 must be open in the
#                                NSG and a DNS A record must point at the
#                                VM's public IP.
#
#   :80                          Dev-only fallback. SSO will NOT work
#                                here — Entra rejects http redirect URIs.
SITE_ADDRESS=claudelab.ntiva.com
ACME_EMAIL=admin@example.com

# Ports the Caddy container publishes on the host.
# Production (TLS): 80:80, 443:443  (root or cap_net_bind required)
# Dev only:         8080:80
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# --------------------------------------------------------------------------
# SSO — oauth2-proxy + Entra ID (Azure AD)
# --------------------------------------------------------------------------
# See docs/SSO.md for the one-time Entra app-registration walkthrough.
#
# Tenant: the Entra directory (GUID) you're authenticating against.
OIDC_TENANT_ID=00000000-0000-0000-0000-000000000000

# App registration: from Entra → App registrations → <your app> → Overview.
OIDC_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Client secret: from App registration → Certificates & secrets.
# Treat this like a password — never commit. It's read by oauth2-proxy.
OIDC_CLIENT_SECRET=replace-me

# Cookie secret: 32 random bytes, base64-encoded. Generate with:
#   openssl rand -base64 32
# Rotating it invalidates every active session.
OAUTH2_PROXY_COOKIE_SECRET=replace-me-with-32-random-base64-bytes

# Comma-separated email domains allowed to sign in. Anyone authenticated
# by Entra whose email matches gets a workspace; anyone else is rejected
# even if Entra lets them through (defence in depth — control should
# primarily happen via the Entra app-assignment list).
OAUTH2_PROXY_EMAIL_DOMAINS=ntiva.com

# --------------------------------------------------------------------------
# Portal — admin signal
# --------------------------------------------------------------------------
# Entra group object ID whose members get the /admin tab. Find it in
# Entra → Groups → <your admin group> → Overview → Object ID.
# Leave blank to disable group-based admin (env fallback below still works).
ADMIN_GROUP_OID=

# Bootstrap admins by email. Comma-separated. Useful for the very first
# sign-in before the Entra group claim is wired up; also the canonical
# fallback if Entra ever stops emitting the groups claim.
ADMIN_USERS=you@example.com

# --------------------------------------------------------------------------
# Workspace defaults
# --------------------------------------------------------------------------
# Each user is one of two tiers, managed from /admin/users:
#   terminal — ttyd + filebrowser only. Default for new users.
#   desktop  — ttyd + filebrowser + KasmVNC + XFCE4 + Firefox.
# The memory cap is picked per-tier; CPU cap is shared.
WORKSPACE_IMAGE=claudelab-workspace:latest
WORKSPACE_MEMORY_TERMINAL=2g
WORKSPACE_MEMORY_DESKTOP=3g
WORKSPACE_CPUS=1.5
WORKSPACE_IDLE_HOURS=2
