# Copy to .env and edit. The compose file reads from .env automatically.

# --------------------------------------------------------------------------
# Hostname / TLS
# --------------------------------------------------------------------------
# SITE_ADDRESS controls Caddy's site label.
#
#   :80                   (default) HTTP-only, accept any Host header.
#                         Use this for IP-based access without DNS or TLS.
#                         Example URL: http://20.125.57.59:8080/
#
#   box.yourdomain.com    Bind to that hostname; Caddy auto-fetches a real
#                         Let's Encrypt cert on first request. DNS A record
#                         must point at this VM and ports 80+443 must be
#                         open in the NSG.
SITE_ADDRESS=:80
ACME_EMAIL=admin@example.com

# Ports the Caddy container publishes on the host.
# Dev (IP/HTTP):        8080:80   (CADDY_HTTPS_PORT unused)
# Production (HTTPS):   80:80, 443:443  (root / cap_net_bind required)
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443

# --------------------------------------------------------------------------
# Portal
# --------------------------------------------------------------------------
NODE_ENV=production

# Comma-separated usernames who get the /admin page.
# These users must also exist in caddy/users.users (or admins.users).
ADMIN_USERS=admin

# --------------------------------------------------------------------------
# Workspace defaults
# --------------------------------------------------------------------------
# Each user is one of two tiers, managed from /admin/users:
#   terminal — ttyd + filebrowser only. Default for new users.
#   desktop  — ttyd + filebrowser + KasmVNC + XFCE4 + Firefox.
# The memory cap is picked per-tier; CPU cap is shared.
WORKSPACE_IMAGE=browser-linux-workspace:latest
WORKSPACE_MEMORY_TERMINAL=2g
WORKSPACE_MEMORY_DESKTOP=3g
WORKSPACE_CPUS=1.5
WORKSPACE_IDLE_HOURS=2
