{
	# Global options
	# In dev (DOMAIN=localhost) Caddy uses its internal CA / self-signed.
	# In prod, Caddy requests a real cert from Let's Encrypt automatically.
	email {$ACME_EMAIL:admin@example.com}
	# auto_https off  # uncomment to disable HTTPS while iterating
}

# ---------------------------------------------------------------------------
# Reusable auth snippets — populated by scripts/add-user.sh
# Each line:  username  bcrypt_hash
# ---------------------------------------------------------------------------
(user_auth) {
	basic_auth {
		import /etc/caddy/users.users
	}
}

(admin_auth) {
	basic_auth {
		import /etc/caddy/admins.users
	}
}

# ===========================================================================
# Main site
# ---------------------------------------------------------------------------
# SITE_ADDRESS controls how Caddy serves this stack:
#
#   :80            (default)  — bind HTTP on port 80, ANY Host header.
#                               Use for IP-based access without DNS or TLS.
#                               Caddy will NOT auto-enable HTTPS.
#
#   box.you.com    (prod)     — bind both 80 and 443 for that hostname,
#                               auto-fetch a Let's Encrypt cert, redirect
#                               HTTP→HTTPS. DNS A record must point at this
#                               VM and ports 80/443 must be open.
# ===========================================================================
{$SITE_ADDRESS::80} {
	# ----- PUBLIC: marketing landing page + static assets -------------------
	@public path / /static/* /favicon.ico /favicon.svg /robots.txt
	handle @public {
		reverse_proxy portal:3000
	}

	# ----- LOGOUT: poison browser basic-auth cache, then redirect home ------
	# HTTP basic auth has no protocol-level logout. The reliable cross-
	# browser trick is to issue a fetch() with bogus credentials so the
	# browser overwrites its cached creds for the /app realm, then send
	# the user back to /. The page below is served without basic_auth
	# (it's outside the auth-gated routes) so a sign-out works even if
	# the user has already been kicked.
	handle /logout {
		header Content-Type "text/html; charset=utf-8"
		respond 200 `<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Signing out…</title>
<link rel="stylesheet" href="/static/styles.css">
</head>
<body>
<header class="site">
  <a class="brand" href="/"><span class="glyph">_$</span> Browser Linux</a>
</header>
<section class="container" style="text-align:center;padding:80px 24px;">
  <h2>Signing you out…</h2>
  <p class="muted">Clearing cached credentials. Redirecting home.</p>
  <p class="muted small">Tip: closing this browser tab also fully clears HTTP basic-auth credentials.</p>
</section>
<script>
  // Send bogus Basic creds at /app so the browser overwrites whatever
  // it had cached for that realm. Then go home.
  fetch('/app', {
    method: 'HEAD',
    headers: { 'Authorization': 'Basic ' + btoa('logout:logout') },
    cache: 'no-store',
    credentials: 'include'
  }).catch(function () {}).finally(function () {
    setTimeout(function () { window.location.href = '/'; }, 500);
  });
</script>
</body>
</html>`
	}

	# ----- ADMIN: extra-gated, admin-only basicauth -------------------------
	handle /admin* {
		import admin_auth
		reverse_proxy portal:3000 {
			header_up X-Auth-User {http.auth.user.id}
		}
	}

	# ----- USER WORKSPACE: /u/<anything>/[p/<port>/]* -> ws-<auth_user> -----
	# Routing is purely by the authenticated user. The user slot in the URL
	# is ignored — Caddy strips it and proxies to the workspace owned by
	# whoever is authenticated. There is no way to even attempt to reach
	# another user's workspace; alice typing /u/bob/ silently lands in
	# alice's own container.
	#
	# Two upstreams within the workspace:
	#
	#   /u/<slug>/p/<port>/<rest>   →  ws-<auth_user>:<port>/<rest>
	#       Use this to expose any HTTP/WS service you bind on
	#       0.0.0.0:<port> inside your workspace (test webapps, dev
	#       servers, jupyter, anything). Caddy will WebSocket-upgrade
	#       automatically. Use relative URLs in your app or set a
	#       <base href="/u/<slug>/p/<port>/"> for absolute paths.
	#
	#   /u/<slug>/<rest>            →  ws-<auth_user>:7681/<rest>
	#       Default — the in-browser bash terminal (ttyd).
	#
	# `handle_path /u/*` strips the `/u` prefix.
	handle_path /u/* {
		import user_auth

		# Desktop (KasmVNC / XFCE4) — matched first because it's specific
		# and KasmVNC's HTML uses absolute URLs that need the /u/<user>/desktop
		# prefix preserved end-to-end. We rewrite the URL slot to the auth
		# user so KasmVNC's configured `subpath` always matches what arrives.
		@desktop path_regexp udesk ^/[^/]+/desktop(/.*)?$
		handle @desktop {
			rewrite * /u/{http.auth.user.id}/desktop{http.regexp.udesk.1}
			reverse_proxy ws-{http.auth.user.id}:7683
		}

		# File browser (filebrowser).
		@files path_regexp ufiles ^/[^/]+/files(/.*)?$
		handle @files {
			rewrite * /u/{http.auth.user.id}/files{http.regexp.ufiles.1}
			reverse_proxy ws-{http.auth.user.id}:7682
		}

		# Webapp port-proxy.
		@port_proxy path_regexp pport ^/[^/]+/p/(\d+)(/.*)?$
		handle @port_proxy {
			rewrite * {http.regexp.pport.2}
			reverse_proxy ws-{http.auth.user.id}:{http.regexp.pport.1}
		}

		# Everything else → the terminal.
		@user_path path_regexp upath ^/[^/]+(/.*)?$
		handle @user_path {
			rewrite * {http.regexp.upath.1}
			reverse_proxy ws-{http.auth.user.id}:7681
		}
		respond 404
	}

	# ----- AUTHENTICATED APP: dashboard -------------------------------------
	handle /app* {
		import user_auth
		reverse_proxy portal:3000 {
			header_up X-Auth-User {http.auth.user.id}
		}
	}

	handle /api/* {
		import user_auth
		reverse_proxy portal:3000 {
			header_up X-Auth-User {http.auth.user.id}
		}
	}

	# ----- DEFAULT: send anything else to the portal (which 404s) -----------
	handle {
		reverse_proxy portal:3000
	}

	# ----- LOGGING ----------------------------------------------------------
	log {
		output file /var/log/caddy/access.log {
			roll_size 10mb
			roll_keep 10
		}
		format json
	}
}
