{
	# Global options
	email {$ACME_EMAIL:admin@example.com}
}

# ===========================================================================
# Main site — SSO via oauth2-proxy + Entra ID
# ---------------------------------------------------------------------------
# Auth flow:
#   1. Browser → Caddy.
#   2. For everything except /oauth2/*, Caddy issues a forward_auth
#      subrequest to oauth2-proxy:/oauth2/auth. oauth2-proxy validates
#      the session cookie:
#        - Valid: 202 + X-Auth-Request-{Email,User,Groups} headers.
#          Caddy copies those onto the inbound request and continues
#          to the route handler.
#        - Invalid: 401. Caddy intercepts (`@oauth2_auth_fail`) and
#          302s the browser to /oauth2/start?rd=<original-url> so
#          oauth2-proxy can kick off the Entra OIDC handshake.
#   3. /oauth2/* itself is fully proxied (no auth) to oauth2-proxy.
#      This is where /oauth2/start, /oauth2/callback, /oauth2/sign_out
#      live.
#
# Slug derivation:
#   X-Auth-Request-Email is lowercase'd by oauth2-proxy. We use
#   header_regexp to capture the local-part as the workspace slug
#   (USERNAME_RE in the portal matches the same shape). The slug is
#   interpolated into reverse_proxy upstreams as ws-<slug>:<port>.
# ===========================================================================
{$SITE_ADDRESS::80} {
	# ----- OAUTH2-PROXY: login/callback/sign_out endpoints -----------------
	# Full pass-through — must NOT require auth, since this is where the
	# handshake happens. oauth2-proxy handles cookie setting on callback.
	handle /oauth2/* {
		reverse_proxy oauth2-proxy:4180 {
			header_up X-Real-IP {http.request.remote.host}
			header_up X-Forwarded-Host {http.request.host}
			header_up X-Forwarded-Proto {http.request.scheme}
		}
	}

	# ----- FORWARD AUTH: validate session on every other request -----------
	# Sets X-Auth-Request-* response headers on success; Caddy copies them
	# onto the inbound request via copy_headers. On 401 we redirect to
	# /oauth2/start with the original URL preserved for post-login bounce.
	#
	# IMPORTANT: must NOT match /oauth2/* — Caddy's directive order runs
	# forward_auth (at the "auth" slot) BEFORE handle blocks ("handler"
	# slot). Without the @protected matcher, the OIDC callback itself
	# would be intercepted by forward_auth and bounced to /oauth2/start
	# in a loop.
	@protected not path /oauth2/*
	forward_auth @protected oauth2-proxy:4180 {
		uri /oauth2/auth
		copy_headers X-Auth-Request-Email X-Auth-Request-User X-Auth-Request-Groups X-Auth-Request-Preferred-Username

		@auth_failed status 401
		handle_response @auth_failed {
			redir * /oauth2/start?rd={http.request.uri} 302
		}
	}

	# ----- PUBLIC marketing page -------------------------------------------
	# Anything not behind oauth2-proxy still needs to be served; the
	# forward_auth above will redirect unauthenticated visitors away.
	# Authenticated users land on the marketing page like anyone else.
	@public path / /static/* /favicon.ico /favicon.svg /robots.txt
	handle @public {
		reverse_proxy portal:3000 {
			header_up X-Auth-User {http.request.header.X-Auth-Request-Email}
			header_up X-Auth-Groups {http.request.header.X-Auth-Request-Groups}
		}
	}

	# ----- ADMIN: cross-user terminal (admin-only) -------------------------
	# Same as v0.9.20, now gated on Entra group membership instead of
	# admin_auth basic-auth realm. We check that the user's groups header
	# (comma-separated GUIDs from Entra) contains the configured admin
	# group OID.
	#
	# Username regex matches USERNAME_RE in the portal (lib/users.ts) so
	# malformed slots 404 before reaching reverse_proxy / DNS.
	@is_admin header X-Auth-Request-Groups *{$ADMIN_GROUP_OID}*
	handle_path /admin/term/* {
		handle @is_admin {
			@adm_term path_regexp admterm ^/([a-z0-9][a-z0-9._-]{0,40})(/.*)?$
			handle @adm_term {
				rewrite * {http.regexp.admterm.2}
				reverse_proxy ws-{http.regexp.admterm.1}:7681
			}
			respond 404
		}
		respond "Admins only" 403
	}

	# ----- ADMIN: portal-served dashboard / users / ports / logs ----------
	# Portal verifies admin status itself (lib/auth.ts reads
	# X-Auth-Groups). Caddy forwards everything; the portal returns 403
	# for non-admins. This avoids duplicating the admin check between
	# Caddy and the portal for paths the portal already gates.
	handle /admin* {
		reverse_proxy portal:3000 {
			header_up X-Auth-User {http.request.header.X-Auth-Request-Email}
			header_up X-Auth-Groups {http.request.header.X-Auth-Request-Groups}
		}
	}

	# ----- USER WORKSPACE: /u/<anything>/[p/<port>/]* -> ws-<auth_user> ---
	# Slot in the URL is ignored. The slug used for upstream selection is
	# captured from the authenticated user's email — same model as before,
	# just with the email header instead of basic_auth's user.id.
	#
	# All four service handlers below depend on the `@have_slug` matcher
	# populating {http.regexp.slug.1} from X-Auth-Request-Email. The
	# matcher is defined *inside* the handle_path block so its captures
	# are guaranteed to be in scope for the nested handlers — defining it
	# at site level caused Caddy to fail to populate {http.regexp.slug.1}
	# on first prod deploy. If the header is missing or malformed, the
	# whole /u/* tree 502s rather than potentially routing to ws-<empty>.
	handle_path /u/* {
		@have_slug header_regexp slug X-Auth-Request-Email ^([a-z0-9][a-z0-9._-]{0,40})@
		handle @have_slug {
			# Desktop (KasmVNC HTTPS upstream, snakeoil cert).
			@desktop_root path_regexp dskroot ^/[^/]+/desktop/?$
			handle @desktop_root {
				redir * /u/{http.regexp.slug.1}/desktop/index.html?path=u/{http.regexp.slug.1}/desktop/websockify 302
			}

			@desktop path_regexp udesk ^/[^/]+/desktop(/.*)?$
			handle @desktop {
				rewrite * {http.regexp.udesk.1}
				reverse_proxy ws-{http.regexp.slug.1}:7683 {
					transport http {
						tls
						tls_insecure_skip_verify
					}
				}
			}

			# Files (filebrowser).
			@files path_regexp ufiles ^/[^/]+/files(/.*)?$
			handle @files {
				rewrite * /u/{http.regexp.slug.1}/files{http.regexp.ufiles.1}
				reverse_proxy ws-{http.regexp.slug.1}:7682
			}

			# Webapp port-proxy.
			@port_proxy path_regexp pport ^/[^/]+/p/(\d+)(/.*)?$
			handle @port_proxy {
				rewrite * {http.regexp.pport.2}
				reverse_proxy ws-{http.regexp.slug.1}:{http.regexp.pport.1}
			}

			# Terminal (ttyd) — default.
			@user_path path_regexp upath ^/[^/]+(/.*)?$
			handle @user_path {
				rewrite * {http.regexp.upath.1}
				reverse_proxy ws-{http.regexp.slug.1}:7681
			}
			respond 404
		}
		# No usable slug — should never happen because forward_auth
		# would have redirected an unauthenticated user already.
		respond "Auth header missing" 502
	}

	# ----- AUTHENTICATED APP: dashboard + API ----------------------------
	handle /app* {
		reverse_proxy portal:3000 {
			header_up X-Auth-User {http.request.header.X-Auth-Request-Email}
			header_up X-Auth-Groups {http.request.header.X-Auth-Request-Groups}
		}
	}

	handle /api/* {
		reverse_proxy portal:3000 {
			header_up X-Auth-User {http.request.header.X-Auth-Request-Email}
			header_up X-Auth-Groups {http.request.header.X-Auth-Request-Groups}
		}
	}

	# ----- DEFAULT: anything else goes to the portal (404s) ---------------
	handle {
		reverse_proxy portal:3000 {
			header_up X-Auth-User {http.request.header.X-Auth-Request-Email}
			header_up X-Auth-Groups {http.request.header.X-Auth-Request-Groups}
		}
	}

	# ----- LOGGING -------------------------------------------------------
	log {
		output file /var/log/caddy/access.log {
			roll_size 10mb
			roll_keep 10
		}
		format json
	}
}
